{
  "name": "seo-max",
  "version": "2.0.0",
  "description": "AI-powered SEO intelligence for 15+ coding assistants",
  "keywords": [
    "seo",
    "ai",
    "claude",
    "cursor",
    "copilot",
    "optimization",
    "search-engine",
    "web-vitals",
    "schema-markup",
    "content-analysis"
  ],
  "author": "Abhinav Dobhal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhinavdobhal/seo-max.git"
  },
  "homepage": "https://seomax.cc",
  "bugs": {
    "url": "https://github.com/abhinavdobhal/seo-max/issues"
  },
  "private": true,
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "build": "cd cli && npm run build",
    "dev:claude": "npm run sync && cp -r .claude/skills/seo ~/.claude/skills/",
    "dev:cursor": "npm run sync && cp -r .claude/skills/seo ~/.cursor/rules/",
    "dev:copilot": "npm run sync && mkdir -p ~/.copilot/skills && cp -r .claude/skills/seo ~/.copilot/skills/",
    "dev:windsurf": "npm run sync && cp -r .claude/skills/seo ~/.windsurf/skills/",
    "dev:continue": "npm run sync && cp -r .claude/skills/seo ~/.continue/skills/",
    "dev:all": "npm run dev:claude && npm run dev:cursor && npm run dev:copilot && npm run dev:windsurf && npm run dev:continue",
    "sync": "node scripts/sync-assets.js",
    "test": "python3 -m pytest tests/",
    "lint:py": "python3 -m pylint src/seo/scripts/*.py",
    "lint:ts": "cd cli && npm run lint",
    "clean": "rm -rf cli/dist cli/assets .claude/skills/seo",
    "prepare": "npm run sync"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
